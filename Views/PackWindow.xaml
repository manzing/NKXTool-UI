<Window x:Class="NkxToolUI.Views.PackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pack NKX Archive"
        Height="860"
        Width="980"
        MinHeight="760"
        MinWidth="860"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource BodyTextBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20"
          Background="{DynamicResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="HeaderTextBlock"
                       FontSize="26"
                       FontWeight="Bold" />
            <TextBlock x:Name="DescriptionTextBlock"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <GroupBox x:Name="ModeGroupBox"
                  Grid.Row="1"
                  Margin="0,18,0,0"
                  Padding="14">
            <StackPanel>
                <RadioButton x:Name="FolderModeRadioButton"
                             Margin="0,8,0,8"
                             Checked="PackModeRadioButton_OnChecked" />
                <RadioButton x:Name="MultiFolderModeRadioButton"
                             Margin="0,0,0,8"
                             Checked="PackModeRadioButton_OnChecked"
                             Content="Pack multiple folders" />
                <RadioButton x:Name="FileListModeRadioButton"
                             Checked="PackModeRadioButton_OnChecked" />
            </StackPanel>
        </GroupBox>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="SinglePackPanel"
                        Grid.Row="0">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="SourceFolderLabel"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="SourceFolderTextBox"
                             Grid.Column="1" />
                    <Button x:Name="BrowseSourceFolderButton"
                            Grid.Column="2"
                            Margin="12,6,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BrowseSourceFolderButton_OnClick" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="FileListLabel"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="FileListTextBox"
                             Grid.Column="1" />
                    <Button x:Name="BrowseFileListButton"
                            Grid.Column="2"
                            Margin="12,6,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BrowseFileListButton_OnClick" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="RootPathLabel"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="RootPathTextBox"
                             Grid.Column="1" />
                    <Button x:Name="BrowseRootPathButton"
                            Grid.Column="2"
                            Margin="12,6,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BrowseRootPathButton_OnClick" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="OutputArchiveLabel"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="OutputArchiveTextBox"
                             Grid.Column="1" />
                    <Button x:Name="BrowseOutputArchiveButton"
                            Grid.Column="2"
                            Margin="12,6,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BrowseOutputArchiveButton_OnClick" />
                </Grid>
            </StackPanel>

            <StackPanel x:Name="MultiPackPanel"
                        Grid.Row="1"
                        Visibility="Collapsed">
                <TextBlock x:Name="SourceFoldersLabel"
                           Margin="0,0,0,8"
                           FontWeight="SemiBold"
                           Text="Source folders" />

                <ListBox x:Name="SourceFoldersListBox"
                         Height="150"
                         SelectionMode="Extended" />

                <StackPanel Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button x:Name="AddSourceFoldersButton"
                            Width="150"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="AddSourceFoldersButton_OnClick"
                            Content="Add folders" />
                    <Button x:Name="RemoveSourceFoldersButton"
                            Width="150"
                            Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="RemoveSourceFoldersButton_OnClick"
                            Content="Remove selected" />
                </StackPanel>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="OutputFolderLabel"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="Output folder" />
                    <TextBox x:Name="OutputFolderTextBox"
                             Grid.Column="1" />
                    <Button x:Name="BrowseOutputFolderButton"
                            Grid.Column="2"
                            Margin="12,6,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BrowseOutputFolderButton_OnClick"
                            Content="Browse folder" />
                </Grid>

                <CheckBox x:Name="IncludeParentFolderCheckBox"
                          Margin="0,16,0,0"
                          Content="Include parent folder in archive"
                          IsChecked="False" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,18,0,0"
                Padding="14"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock x:Name="HintTextBlock"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <TextBox x:Name="LogTextBox"
                 Grid.Row="5"
                 Margin="0,18,0,0"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 FontFamily="Consolas" />

        <DockPanel Grid.Row="6" Margin="0,18,0,0">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="RunPackButton"
                        Width="150"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="RunPackButton_OnClick" />
                <Button x:Name="CloseWindowButton"
                        Width="110"
                        Margin="0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CloseWindowButton_OnClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>